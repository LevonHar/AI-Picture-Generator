<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".login_fragments.VerifyAccountFragment">

    <ImageView
        android:id="@+id/shadow1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/shadow1"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:translationX="-50dp"
        android:translationY="-250dp" />

    <ImageView
        android:id="@+id/shadow2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:src="@drawable/shadow2"
        android:translationX="50dp"
        android:translationY="350dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/verify_image"
        app:layout_constraintBottom_toTopOf="@+id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Please Verify Account"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/sendToEmailText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Verification Code Input -->
    <LinearLayout
        android:id="@+id/llCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 6 EditTexts for code -->
        <EditText
            android:id="@+id/etCode1"
            style="@style/CodeEditText" />

        <EditText
            android:id="@+id/etCode2"
            style="@style/CodeEditText" />

        <EditText
            android:id="@+id/etCode3"
            style="@style/CodeEditText" />

        <EditText
            android:id="@+id/etCode4"
            style="@style/CodeEditText" />

        <EditText
            android:id="@+id/etCode5"
            style="@style/CodeEditText" />

        <EditText
            android:id="@+id/etCode6"
            style="@style/CodeEditText" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvResendCode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Resend Code"
        android:textColor="#9CA3AF"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="@+id/llCode"
        app:layout_constraintTop_toBottomOf="@+id/llCode" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:text="02:00"
        android:textColor="#9CA3AF"
        android:textSize="15sp"
        app:layout_constraintEnd_toStartOf="@+id/timeImage"
        app:layout_constraintTop_toBottomOf="@+id/llCode" />


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/verifyCodeButton"
        android:layout_width="160dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/button"
        android:text="Verify Code"
        android:textAllCaps="false"
        android:textColor="#F3F4F6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvResendCode" />

    <ImageView
        android:id="@+id/timeImage"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/time_icon"
        app:layout_constraintEnd_toEndOf="@+id/llCode"
        app:layout_constraintTop_toBottomOf="@+id/llCode" />

    <TextView
        android:id="@+id/sendToEmailText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:textSize="14dp"
        android:textColor="#9CA3AF"
        android:text="Code sent to harutyunyanlevon99@gmail.com"
        app:layout_constraintBottom_toTopOf="@+id/llCode"
        app:layout_constraintEnd_toEndOf="@+id/llCode"
        app:layout_constraintStart_toStartOf="@+id/llCode" />

</androidx.constraintlayout.widget.ConstraintLayout>