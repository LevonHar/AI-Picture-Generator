<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/dialog_background">

    <!-- Sticky Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingStart="24dp"
        android:background="@drawable/dialog_background">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Text"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <!-- Preview Text - Sticky at top -->
        <FrameLayout
            android:id="@+id/previewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@drawable/preview_background"
            android:padding="16dp">

            <TextView
                android:id="@+id/previewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Preview Text"
                android:textSize="24sp"
                android:gravity="center"
                android:visibility="visible" />

            <!-- Curved preview will be added programmatically -->
        </FrameLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/textInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter your text"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:maxLines="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Color"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/colorChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:orientation="horizontal"
                app:chipSpacing="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/colorBlack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Black"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#000000"
                    app:chipIconTint="@color/white"
                    app:checkedIconVisible="true"
                    app:checkedIcon="@drawable/ic_check" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/colorWhite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="White"
                    android:textColor="@color/black"
                    app:chipBackgroundColor="#FFFFFF"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="#E0E0E0"
                    app:checkedIconVisible="true"
                    app:checkedIcon="@drawable/ic_check" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/colorRed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Red"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#F44336"
                    app:checkedIconVisible="true"
                    app:checkedIcon="@drawable/ic_check" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/colorBlue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blue"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#2196F3"
                    app:checkedIconVisible="true"
                    app:checkedIcon="@drawable/ic_check" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/colorCustom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Custom"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#9C27B0"
                    app:chipIconTint="@color/white"
                    app:checkedIconVisible="true"
                    app:checkedIcon="@drawable/ic_check" />

            </com.google.android.material.chip.ChipGroup>

            <!-- Font Selection Dropdown -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/fontDropdownLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                <AutoCompleteTextView
                    android:id="@+id/fontDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Font"
                    android:text="Default"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Size"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/textSizeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="12"
                android:valueTo="48"
                android:value="24"
                android:stepSize="2"
                android:layout_marginBottom="16dp" />

            <!-- Text Transparency Slider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Transparency"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/transparencySlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="0"
                android:stepSize="1"
                android:layout_marginBottom="24dp" />

            <!-- Background Color Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Color"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/bgColorChipGroup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:singleSelection="true"
                    app:selectionRequired="false"
                    android:orientation="horizontal"
                    app:chipSpacing="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/bgColorTransparent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="None"
                        android:textColor="@color/black"
                        app:chipBackgroundColor="#F0F0F0"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="#E0E0E0"
                        app:checkedIconVisible="true"
                        app:checkedIcon="@drawable/ic_check" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/bgColorBlack"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Black"
                        android:textColor="@color/white"
                        app:chipBackgroundColor="#000000"
                        app:checkedIconVisible="true"
                        app:checkedIcon="@drawable/ic_check" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/bgColorWhite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="White"
                        android:textColor="@color/black"
                        app:chipBackgroundColor="#FFFFFF"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="#E0E0E0"
                        app:checkedIconVisible="true"
                        app:checkedIcon="@drawable/ic_check" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/bgColorRed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Red"
                        android:textColor="@color/white"
                        app:chipBackgroundColor="#F44336"
                        app:checkedIconVisible="true"
                        app:checkedIcon="@drawable/ic_check" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/bgColorBlue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Blue"
                        android:textColor="@color/white"
                        app:chipBackgroundColor="#2196F3"
                        app:checkedIconVisible="true"
                        app:checkedIcon="@drawable/ic_check" />

                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.chip.Chip
                    android:id="@+id/bgColorCustom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Custom"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#9C27B0"
                    app:checkedIconVisible="true"
                    app:checkedIcon="@drawable/ic_check" />

            </LinearLayout>

            <!-- Background Transparency Slider -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Transparency"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/bgTransparencySlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                android:value="100"
                android:stepSize="1"
                android:layout_marginBottom="16dp"
                android:enabled="false" />

            <!-- Rotation Control -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Rotation"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/rotationSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0"
                    android:valueTo="360"
                    android:value="0"
                    android:stepSize="1"
                    android:layout_marginEnd="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/rotationValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:inputType="number"
                        android:gravity="center"
                        android:maxLength="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="°"
                    android:textSize="16sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Curve Text Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Curve Text"
                    android:textSize="16sp"
                    android:textColor="@color/black" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/curveToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Curve Controls (initially hidden) -->
            <LinearLayout
                android:id="@+id/curveControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curve Radius"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.slider.Slider
                        android:id="@+id/curveRadiusSlider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="50"
                        android:valueTo="500"
                        android:value="200"
                        android:stepSize="10"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/curveRadiusValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="200"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curve Direction"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/curveDirectionToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/curveDirectionUp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Up"
                        style="?attr/materialButtonOutlinedStyle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/curveDirectionDown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Down"
                        style="?attr/materialButtonOutlinedStyle" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cancelButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Cancel"
                    style="@style/Widget.Material3.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/confirmButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Add Text"
                    style="@style/Widget.Material3.Button" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>