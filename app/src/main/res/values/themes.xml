<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Logix" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="android:windowBackground">@color/theme_background</item>
        <item name="android:statusBarColor">@color/theme_background</item>
    </style>

    <style name="Theme.Logix" parent="Base.Theme.Logix" />

    <!-- res/values/styles.xml -->
    <style name="CodeEditText">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18dp</item>
        <item name="android:inputType">number</item>
        <item name="android:background">@drawable/edit_text_verify_background</item>
    </style>

    <style name="MediumTextViewThin">
        <item name="android:textColor">#4b4f60</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">@font/sf_pro_display</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SmallTextViewThin">
        <item name="android:textColor">#4b4f60</item>
        <item name="android:textSize">10sp</item>
        <item name="fontFamily">@font/sf_pro_display</item>
    </style>

</resources>